# NarratorAI Omega 环境变量
# LLM API — 支持任意 OpenAI 兼容的中转API
# 常见中转：空氧(aibh.site) / OneAPI / New API / OpenRouter / 硅基流动 / DeepSeek 等
LLM_BASE_URL=https://api.aibh.site/v1
LLM_API_KEY=sk-sp-eb231d8523924e338a7318ffa239c12c
LLM_MODEL=gpt-5
LLM_FALLBACK_MODEL=gpt-4o

# 空氧(KongYang) API Key — 用于 motion-prompt / video-gen-multi / manga-pipeline / novel-to-drama / novel-workshop
KONGYANG_API_KEY=sk-sp-eb231d8523924e338a7318ffa239c12c

# TTS 语音合成配置
# 方式1: 音谷(SonicVale) 本地部署 - 填音谷后端地址如 http://localhost:8200
# 方式2: 仙宫云 Index-TTS - 填仙宫云实例地址如 https://xxx.cnb.run
TTS_API_URL=https://er2bcoyn3nrv97tx-8300.container.x-gpu.com
TTS_API_KEY=
# 音谷参考音频路径（用于 Index-TTS 的音色克隆）
TTS_REF_AUDIO=张晨声音.WAV
# 客户端可读的默认参考音频（多角色配音默认旁白用）
NEXT_PUBLIC_TTS_REF_AUDIO=张晨声音.WAV

# OpenStoryline MCP Server
STORYLINE_MCP_URL=http://127.0.0.1:8001

# Sora 自动化 - 比特浏览器模式
SORA_MODE=bitbrowser
BITBROWSER_IDS=58daaf9b9b8d41148138faa77a1fa68d,4e1e946c7d074b3bab76d8bdb11b1ea2

# Sora API 模式（SORA_MODE=api 时生效）
# 方式1: 环境变量配置（多账号池）
# SORA_ACCOUNTS=https://api.example.com/v1|sk-xxx|账号1,https://api2.example.com/v1|sk-yyy|账号2
# 方式2: 单账号
# SORA_API_BASE=https://api.example.com/v1
# SORA_API_KEY=sk-xxx
# SORA_API_MODEL=sora-2
# 方式3: 前端页面直接填写（无需配置环境变量，在 UI 中勾选"使用自定义 API 配置"）
