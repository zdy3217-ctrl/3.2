# NarratorAI Omega 环境变量模板
# 复制为 .env.local 并填入实际值

# === LLM 核心配置 ===
# 支持任意 OpenAI 兼容的中转API（空氧/OneAPI/OpenRouter/硅基流动/DeepSeek 等）
LLM_BASE_URL=https://api.aibh.site/v1
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash
LLM_FALLBACK_MODEL=gemini-2.0-flash

# 备用 LLM（可选，用于 provider 降级）
LLM_FALLBACK_URL=
LLM_FALLBACK_KEY=

# === TTS 语音合成 ===
# 方式1: 音谷(SonicVale) 本地部署 - 填音谷后端地址如 http://localhost:8200
# 方式2: 仙宫云 Index-TTS - 填仙宫云实例地址如 https://xxx.cnb.run
TTS_API_URL=
TTS_API_KEY=
TTS_REF_AUDIO=
NEXT_PUBLIC_TTS_REF_AUDIO=

# === 管理员认证 ===
ADMIN_SECRET=

# === 空氧 API ===
KONGYANG_API_KEY=

# === Sora 视频生成 ===
# 模式: api | browser | bitbrowser
SORA_MODE=api
BITBROWSER_IDS=

# Sora API 模式配置（SORA_MODE=api 时）
# 多账号池: SORA_ACCOUNTS=url1|key1|名称1,url2|key2|名称2
SORA_ACCOUNTS=
# 单账号:
SORA_API_BASE=
SORA_API_KEY=
SORA_BASE_URL=

# === 外部服务 ===
STORYLINE_MCP_URL=http://127.0.0.1:8001
PEXELS_API_KEY=
PIXABAY_API_KEY=
DINGTALK_WEBHOOK=

# === 视频审查 ===
INSPECTOR_MODEL=gemini-2.5-flash-preview
INSPECT_MIN_SCORE=65

# === 视频自动审查 ===
AUTO_INSPECT=

# === 其他 ===
HOT_API_BASE=
NEXT_PUBLIC_BASE_URL=http://localhost:3000
